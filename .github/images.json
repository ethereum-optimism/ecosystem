{
  "shared_paths": [
    ".github/workflows/factory.yaml",
    ".github/images.json",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "apko/**"
  ],
  "images": {
    "ecosystem-autorelayer-interop": {
      "mode": "apko",
      "apko_config": "apko/ecosystem-autorelayer-interop.apko.yaml",
      "melange_configs": "apko/ecosystem-autorelayer-interop.melange.yaml",
      "tag": "latest",
      "paths": ["apps/autorelayer-interop/**", "lib/**", "packages/**", "apko/**"]
    },
    "ecosystem-ponder-interop": {
      "mode": "apko",
      "apko_config": "apko/ecosystem-ponder-interop.apko.yaml",
      "melange_configs": "apko/ecosystem-ponder-interop.melange.yaml",
      "tag": "latest",
      "paths": ["apps/ponder-interop/**", "lib/**", "packages/**", "apko/**"]
    },
    "ecosystem-sponsored-sender": {
      "mode": "apko",
      "apko_config": "apko/ecosystem-sponsored-sender.apko.yaml",
      "melange_configs": "apko/ecosystem-sponsored-sender.melange.yaml",
      "tag": "latest",
      "paths": ["apps/sponsored-sender/**", "lib/**", "packages/**", "apko/**"]
    }
  }
}
